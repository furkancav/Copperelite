# CuLister — environment variables
# Bu dosyayı ".env" olarak kopyala ve değerleri doldur (local çalıştırma için).
# Render'da ise bu anahtarları panelden "Environment" olarak gir.

# === Etsy API ===
# https://www.etsy.com/developers/your-apps -> uygulamandan keystring + shared secret
ETSY_API_KEY=your_etsy_keystring_here
ETSY_API_SECRET=your_etsy_shared_secret_here
ETSY_REDIRECT_URI=https://example.com/callback

# Etsy OAuth token (SADECE bulut/Render için).
# Local'de "python run.py auth" ile data/etsy_token.json oluşur; bulutta dosya olmadığı
# için o dosyanın içeriğini TEK SATIR olarak buraya yapıştır.
ETSY_TOKEN_JSON=

# === Görsel üretimi ===
# BİRİNCİL: OpenAI gpt-image-1 — en iyi ürün tutarlılığı. https://platform.openai.com/api-keys
# (gpt-image-1 için OpenAI hesabında organizasyon doğrulaması gerekir)
OPENAI_API_KEY=your_openai_key_here
# Görsel kalitesi: low | medium | high  (varsayılan: medium)
OPENAI_IMAGE_QUALITY=medium
# YEDEK: OpenAI çalışmazsa fal.ai Flux Kontext'e düşer. https://fal.ai/dashboard/keys
FAL_KEY=your_fal_key_here

# === Metin üretimi (Google Gemini) ===
# https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_key_here

# === Kullanıcı adı + şifre koruması (bulut paylaşımı için) ===
# APP_PASSWORD boşsa koruma KAPALI. Ortaklarınla paylaşırken mutlaka bir şifre gir.
# APP_USERNAME verilmezse varsayılan "copper" olur.
APP_USERNAME=copper
APP_PASSWORD=

# === Fiyatlandırma ===
TRY_TO_USD=0.030
PRICE_MULTIPLIER=2.2

# === Kârlılık tablosu (Google Sheet — Apps Script webhook) ===
# Listing oluşunca varyasyonları "Kar Takibi" sekmesine yazar. Boşsa atlanır.
SHEETS_WEBHOOK_URL=
SHEETS_WEBHOOK_TOKEN=
